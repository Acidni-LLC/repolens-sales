---
// Footer component for RepoLens sales site
const currentYear = new Date().getFullYear();

const navigation = {
  product: [
    { name: 'Features', href: '#features' },
    { name: 'Pricing', href: '#pricing' },
    { name: 'Changelog', href: '#' },
    { name: 'Roadmap', href: '#' },
  ],
  resources: [
    { name: 'Documentation', href: '#' },
    { name: 'API Reference', href: '#' },
    { name: 'GitHub', href: 'https://github.com/Acidni-LLC/repolens' },
    { name: 'Status', href: '#' },
  ],
  company: [
    { name: 'About Acidni', href: 'https://www.acidni.com' },
    { name: 'Blog', href: '#' },
    { name: 'Careers', href: '#' },
    { name: 'Contact', href: 'mailto:sales@acidni.net' },
  ],
  legal: [
    { name: 'Privacy Policy', href: '#' },
    { name: 'Terms of Service', href: '#' },
    { name: 'Security', href: '#' },
  ],
};
---

<footer class="bg-gray-900 text-gray-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <svg class="h-8 w-8 text-primary-500" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="currentColor" />
            <path d="M10 16C10 12.686 12.686 10 16 10C19.314 10 22 12.686 22 16C22 19.314 19.314 22 16 22" stroke="white" stroke-width="2" stroke-linecap="round" />
            <circle cx="16" cy="16" r="2" fill="white" />
            <path d="M8 8L12 12M24 24L20 20" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="text-lg font-bold text-white">RepoLens</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          Manifest-first code review for GitHub. Understand any repository's infrastructure in minutes.
        </p>
        <!-- Social Links -->
        <div class="flex space-x-4 mt-6">
          <a href="https://twitter.com/acidni_llc" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">Twitter</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
          <a href="https://github.com/Acidni-LLC" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">GitHub</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://linkedin.com/company/acidni" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">
            <span class="sr-only">LinkedIn</span>
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Product</h3>
        <ul class="space-y-3">
          {navigation.product.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">{item.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-3">
          {navigation.resources.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{item.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          {navigation.company.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{item.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="col-span-2 md:col-span-1">
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-3">
          {navigation.legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">{item.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Acidni LLC. All rights reserved.
      </p>
      <p class="text-xs text-gray-600 mt-2 sm:mt-0">
        RepoLens v{new Date().getFullYear().toString().slice(-2)}{(new Date().getMonth()+1).toString().padStart(2,'0')}{new Date().getDate().toString().padStart(2,'0')}-{new Date().getUTCHours().toString().padStart(2,'0')}{new Date().getUTCMinutes().toString().padStart(2,'0')}
      </p>
    </div>
  </div>
</footer>
